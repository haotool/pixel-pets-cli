{
  "name": "pixel-pets-cli",
  "version": "2.5.0",
  "description": "Collect cute ASCII companions!",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pixel-pets-cli": "dist/index.js",
    "pixel-pets": "dist/index.js",
    "ppets": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build && npm run build:test && node --test dist-test/**/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "terminal",
    "game",
    "pet",
    "collection",
    "ascii-art",
    "gacha",
    "npx",
    "animation"
  ],
  "author": "haotool",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haotool/pixel-pets-cli.git"
  },
  "homepage": "https://github.com/haotool/pixel-pets-cli#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.2.0",
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
